<apex:page standardController="Opportunity" extensions="ProposalExtension" renderAs="pdf" applyHtmlTag="false" showHeader="false"
    cache="true">

    <head>
        <apex:stylesheet value="{!$Resource.ProposalStyles}" />
    </head>

    <div class="header">
        <h1>Project Proposal</h1>
        <p>Prepared for: {!Opportunity.Account.Name}</p>
        <p>Date:
            <apex:outputText value="{0, date, MMMM d, yyyy}">
                <apex:param value="{!TODAY()}" /></apex:outputText>
        </p>
    </div>
    <apex:pageMessages />
    <table>
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            <apex:repeat value="{!lineItems}" var="item">
                <tr>
                    <td>{!item.Product2.Name}</td>
                    <td>{!item.Quantity}</td>
                    <td>
                        <apex:outputField value="{!item.UnitPrice}" />
                    </td>
                    <td>
                        <apex:outputField value="{!item.TotalPrice}" />
                    </td>
                </tr>
            </apex:repeat>
        </tbody>
    </table>
    <div class="total-section">
        <p>Tax (10%):
            <apex:outputText value="{0, number, currency}">
                <apex:param value="{!regTax}" /></apex:outputText>
        </p>
        <p>Grand Total:
            <apex:outputText value="{0, number, currency}">
                <apex:param value="{!grandTotal}" /></apex:outputText>
        </p>
    </div>
</apex:page>